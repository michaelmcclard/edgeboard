# EdgeBoard Environment Variables
# Copy this file to .env and fill in your API keys

# External APIs
ODDS_API_KEY=
OPENWEATHER_API_KEY=
SPORTSRADAR_API_KEY=
NEWS_API_KEY=
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App Config
EDGEBOARD_ENV=development
EDGEBOARD_TIMEZONE=America/Chicago
EDGEBOARD_BASE_URL=http://localhost:8000
